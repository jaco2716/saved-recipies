{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/recipe.schema.json",
  "title": "Opskriftssamling",
  "description": "Skema for samlingen af opskrifter. Bruges til validering og autofuldførelse i editoren.",
  "type": "object",
  "required": ["recipes"],
  "properties": {
    "$schema": { "type": "string" },
    "version": {
      "type": "integer",
      "description": "Dataformatets version. Øges hvis strukturen ændres.",
      "minimum": 1
    },
    "recipes": {
      "type": "array",
      "description": "Alle opskrifter.",
      "items": { "$ref": "#/definitions/recipe" }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "recipe": {
      "type": "object",
      "required": ["slug", "title", "ingredients", "steps"],
      "additionalProperties": false,
      "properties": {
        "slug": {
          "type": "string",
          "description": "Unikt id brugt i URL'en, fx 'pandekager'. Kun små bogstaver, tal og bindestreg.",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "description": "Opskriftens navn.",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "description": "Kort beskrivelse vist på forsiden."
        },
        "emoji": {
          "type": "string",
          "description": "Emoji brugt som ikon for opskriften, fx '🥞'."
        },
        "image": {
          "type": "string",
          "description": "Valgfrit billede. Sti relativ til projektets rod, fx 'assets/images/tunsalat.jpg'."
        },
        "category": {
          "type": "string",
          "description": "Kategori opskriften hører til, fx 'Dessert'."
        },
        "tags": {
          "type": "array",
          "description": "Frie nøgleord til søgning og filtrering.",
          "items": { "type": "string" }
        },
        "servings": {
          "type": "string",
          "description": "Antal portioner/stykker som tekst, fx 'ca. 10 stk.'."
        },
        "baseServings": {
          "type": "integer",
          "description": "Antal portioner ingrediensmængderne er beregnet til. Bruges til at skalere indkøbslisten. Standard er 1, hvis feltet mangler.",
          "minimum": 1
        },
        "time": {
          "type": "string",
          "description": "Tilberedningstid som tekst, fx '30 min' eller '2 timer (med hævning)'. Vises på opskriften."
        },
        "timeMinutes": {
          "type": "integer",
          "description": "Aktiv tilberedningstid i minutter. Bruges til at sortere forsiden efter tid.",
          "minimum": 0
        },
        "pricePerServing": {
          "type": "number",
          "description": "Estimeret pris pr. person i danske kroner. Bruges til visning og sortering.",
          "minimum": 0
        },
        "calories": {
          "type": "string",
          "description": "Valgfrit energiindhold, fx 'ca. 320 kcal'."
        },
        "protein": {
          "type": "string",
          "description": "Valgfrit proteinindhold, fx 'ca. 40 g'."
        },
        "ingredients": {
          "type": "array",
          "description": "Liste af ingredienser som referencer til ingrediens-kataloget (data/ingredients.json).",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["ref"],
            "additionalProperties": false,
            "properties": {
              "ref": {
                "type": "string",
                "description": "Id på en ingrediens i data/ingredients.json.",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              },
              "amount": {
                "type": "number",
                "description": "Mængde (valgfri). Skaleres efter portioner på indkøbslisten.",
                "minimum": 0
              },
              "unit": {
                "type": "string",
                "description": "Enhed, fx 'g', 'dl', 'spsk', 'fed', 'dåse'. Udelades for stk."
              },
              "note": {
                "type": "string",
                "description": "Uddybning/tilberedning, fx 'i tern', 'drænet og skyllet'."
              },
              "optional": {
                "type": "boolean",
                "description": "Sæt til true for ingredienser 'efter smag'/'(valgfrit)'."
              }
            }
          }
        },
        "steps": {
          "type": "array",
          "description": "Fremgangsmåden trin for trin.",
          "items": { "type": "string" },
          "minItems": 1
        },
        "notes": {
          "type": "string",
          "description": "Valgfri noter, tips eller variationer."
        }
      }
    }
  }
}
